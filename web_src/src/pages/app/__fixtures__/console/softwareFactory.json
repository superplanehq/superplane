{
  "organizationId": "a1000001-0000-4000-8000-000000000001",
  "canvasId": "a1000001-0000-4000-8000-000000000002",
  "canvasName": "Software Factory",
  "consoleYaml": "apiVersion: v1\nkind: Console\nmetadata:\n  canvasId: a1000001-0000-4000-8000-000000000002\n  name: Software Factory\nspec:\n  layout:\n    - i: latest-merge\n      x: 0\n      \"y\": 0\n      w: 12\n      h: 5\n      minW: 6\n      minH: 4\n    - i: ai-authored\n      x: 0\n      \"y\": 5\n      w: 4\n      h: 5\n      minW: 3\n      minH: 4\n    - i: ai-spend\n      x: 4\n      \"y\": 5\n      w: 4\n      h: 5\n      minW: 3\n      minH: 4\n    - i: active-engineers\n      x: 8\n      \"y\": 5\n      w: 4\n      h: 5\n      minW: 3\n      minH: 4\n    - i: recent-merges\n      x: 0\n      \"y\": 10\n      w: 7\n      h: 10\n      minW: 5\n      minH: 6\n    - i: spend-vs-prs\n      x: 7\n      \"y\": 10\n      w: 5\n      h: 10\n      minW: 4\n      minH: 6\n    - i: pr-health\n      x: 0\n      \"y\": 20\n      w: 12\n      h: 9\n      minW: 6\n      minH: 6\n  panels:\n    - id: latest-merge\n      type: spotlight\n      content:\n        title: Latest merge\n        dataSource:\n          kind: memory\n          namespace: recentMerges\n        kicker: Just landed\n        statusField: status\n        statusLabelField: statusLabel\n        actorNameField: authorName\n        actorAvatarField: authorAvatar\n        titleField: title\n        hrefField: href\n        subtitleField: subtitle\n        timestampField: mergedAt\n        durationField: cycleTimeMs\n        approverNameField: approver\n        approverAvatarField: approverAvatar\n        approverLabel: Approved by\n        checksField: checks\n        checkNameField: name\n        checkStatusField: status\n    - id: ai-authored\n      type: scorecard\n      content:\n        title: AI-assisted merges\n        dataSource:\n          kind: memory\n          namespace: aiAuthoredPct\n        render:\n          kind: scorecard\n          aggregation: first\n          field: value\n          label: AI-assisted PRs\n          format: percent\n          better: up\n          showChange: both\n          changeCaption: vs prior day\n          target: \"70\"\n          showProgress: true\n          sparklineField: value\n    - id: ai-spend\n      type: scorecard\n      content:\n        title: AI spend (7d)\n        dataSource:\n          kind: memory\n          namespace: aiSpendUsd\n        render:\n          kind: scorecard\n          aggregation: first\n          field: value\n          label: USD this week\n          format: number\n          prefix: \"$\"\n          better: down\n          showChange: both\n          changeCaption: vs prior day\n          sparklineField: value\n    - id: active-engineers\n      type: scorecard\n      content:\n        title: Active contributors\n        dataSource:\n          kind: memory\n          namespace: activeContributors\n        render:\n          kind: scorecard\n          aggregation: first\n          field: value\n          label: Engineers\n          format: number\n          better: up\n          showChange: number\n          changeCaption: vs prior day\n          sparklineField: value\n    - id: recent-merges\n      type: table\n      content:\n        title: Recent merges\n        dataSource:\n          kind: memory\n          namespace: recentMerges\n        render:\n          kind: table\n          columns:\n            - field: authorAvatar\n              label: Author\n              format: avatar\n              avatarCommitterField: authorName\n            - field: title\n              label: Pull request\n              format: link\n              href: \"{{ href }}\"\n            - field: authorship\n              label: Authorship\n              format: badge\n            - field: cycleTimeMs\n              label: Cycle time\n              format: duration\n              showTrend: true\n              trendBetter: down\n              trendDisplay: percent\n            - field: checksPassed\n              label: Checks\n              format: progress\n              progressTarget: checksTotal\n              progressLabel: number\n    - id: spend-vs-prs\n      type: table\n      content:\n        title: AI spend vs merged PRs\n        dataSource:\n          kind: memory\n          namespace: engineerThroughput\n        render:\n          kind: table\n          sort:\n            field: mergedPrs\n            order: desc\n          columns:\n            - field: avatar\n              label: Engineer\n              format: avatar\n              avatarCommitterField: person\n            - field: person\n              label: Name\n            - field: mergedPrs\n              label: Merged\n              format: number\n              showTrend: true\n              trendBetter: up\n              trendDisplay: value\n            - field: aiSpendUsd\n              label: AI $\n              format: number\n            - field: aiAssistedPct\n              label: AI %\n              format: percent\n              showTrend: true\n              trendBetter: up\n    - id: pr-health\n      type: table\n      content:\n        title: PR health (weekly)\n        dataSource:\n          kind: memory\n          namespace: prHealth\n        render:\n          kind: table\n          columns:\n            - field: week\n              label: Week\n            - field: medianReviewHours\n              label: Review latency (h)\n              format: number\n              showTrend: true\n              trendBetter: down\n              trendDisplay: percent\n            - field: medianSizeLoc\n              label: Median size (LOC)\n              format: number\n              showTrend: true\n              trendBetter: down\n            - field: reopenRate\n              label: Reopen rate\n              format: percent\n              showTrend: true\n              trendBetter: down\n            - field: mergeRate\n              label: Merge rate\n              format: percent\n              showTrend: true\n              trendBetter: up\n",
