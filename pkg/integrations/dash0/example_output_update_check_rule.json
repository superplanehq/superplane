    "interval": "1m",
    "for": "30s",
    "keepFiringFor": "5m",
    "labels": {
      "severity": "high",
      "team": "backend"
    },
    "annotations": {
      "runbook": "https://wiki.example.com/runbooks/high-error-rate",
