#
# == Agent
#
# AI model to use for the agent
#
# 1. Go to Claude Console and create a new API key
# 2. Copy the API key and fill it in here

AI_MODEL="anthropic:claude-sonnet-4-6"
ANTHROPIC_API_KEY="..."

#
# == SuperPlane app (agent + evals)
#
# URL of the SuperPlane app API. Inside docker compose the default is http://app:8000.

SUPERPLANE_BASE_URL="http://app:8000"

#
# == Eval bootstrap (one-time / when tokens change)
#
# Run: make agent.evals.bootstrap — merges EVAL_ORG_ID, EVAL_CANVAS_ID, SUPERPLANE_API_TOKEN,
# SUPERPLANE_BASE_URL into this file (updates existing keys). Uses compose `run --env-from-file`.
#
# Fresh DB (no users yet) — creates first org + owner via POST /api/v1/setup-owner:
#
# EVAL_BOOTSTRAP_OWNER_EMAIL="dev@example.com"
# EVAL_BOOTSTRAP_OWNER_PASSWORD="choose-a-strong-password"
# EVAL_BOOTSTRAP_OWNER_FIRST_NAME="Dev"
# EVAL_BOOTSTRAP_OWNER_LAST_NAME="User"
#
# Existing instance (required unless you use setup-owner above) — password login:
#
# EVAL_BOOTSTRAP_EMAIL="dev@example.com"
# EVAL_BOOTSTRAP_PASSWORD="..."
#
# (You can reuse EVAL_BOOTSTRAP_OWNER_EMAIL / EVAL_BOOTSTRAP_OWNER_PASSWORD instead if set.)
#
# Optional: pick an org when the account has several (ignored if setup-owner just created the org):
# EVAL_BOOTSTRAP_ORG_ID="00000000-0000-0000-0000-000000000000"
#
# Optional resource names (defaults: canvas "Agent evals", service account "agent-evals"):
# EVAL_BOOTSTRAP_CANVAS_NAME="Agent evals"
# EVAL_BOOTSTRAP_SERVICE_ACCOUNT_NAME="agent-evals"

#
# == Eval runtime (output of bootstrap, or set manually)
#

EVAL_CANVAS_ID="..."
EVAL_ORG_ID="..."
SUPERPLANE_API_TOKEN="..."