#
# == Agent
# 
# AI model to use for the agent
#
# 1. Go to Claude Console and create a new API key
# 2. Copy the API key and fill it in here

AI_MODEL="anthropic:claude-sonnet-4-6"
ANTHROPIC_API_KEY="..."

# Anthropic prompt caching (system + tool definitions; optional message-side cache).
# Disable entirely with AI_PROMPT_CACHE=0.
AI_PROMPT_CACHE=1
# TTL for cache breakpoints: 5m or 1h (default 1h). Applies to each enabled breakpoint.
AI_ANTHROPIC_CACHE_TTL=1h
# Cache conversation messages (1 of 4 Anthropic cache points). Set to 0 to keep only system+tools.
AI_ANTHROPIC_CACHE_MESSAGES=1
# Parallel tool calls (e.g. describe_component + describe_trigger in one step) are enabled in code for Claude.

#
# == Evals
#
# For running evaluation with make test.agent.evals
#
# 1. Create a new organization localhost
# 2. Create a new canvas in the organization
# 3. Create a new service account in the organization
#
# TODO: Automate this process, and use test environment instead of development
#

EVAL_CANVAS_ID="..."
EVAL_ORG_ID="..."
SUPERPLANE_API_TOKEN="..."